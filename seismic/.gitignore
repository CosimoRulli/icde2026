# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb


# Output/groundtruth files
*.tsv


# Virtual environment
.venv/
venv/
env/

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd


# Maturin build output
dist/
build/
*.egg-info/

# macOS
.DS_Store

# Windows
Thumbs.db

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

cached_adjacency*

# Private benchmarking results (not for public release)
private_benchmarking/

# Claude Code
.claude/

# Grid-search run artifacts (kept on disk, not in git)
grid_msmarco_*/
grid_search_msmarco*/
grid_seismic_*/

# Jupyter virtual documents cache
.virtual_documents/
**/.virtual_documents/

# ICDE2026 experiments: only grid_search.toml and best_configs/ are committed.
# Raw grid-search output (building_combination_*, the wrapper grid_* dirs,
# space_usage.tsv at the cell root) lives on disk only.
experiments/ICDE2026/**/building_combination_*/
experiments/ICDE2026/**/grid_msmarco_*/
experiments/ICDE2026/**/grid_seismic_*/

# Per-run experiment output directories (the actual evaluation runs). These are
# named with a trailing timestamp (..._YYYY-MM-DD_HH:MM:SS) and live alongside
# the committed recall_*.toml configs under best_configs/. Keep configs, not runs.
experiments/ICDE2026/**/*_20??-??-??_??:??:??/